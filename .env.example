# Face Attendance System - Environment Variables
# Copy file này thành .env và điền các giá trị thực

# ========================
# Database
# ========================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=face_attendance
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_STRONG_PASSWORD@localhost:5433/face_attendance

# ========================
# Backend App
# ========================
DEBUG=false
SECRET_KEY=CHANGE_ME_GENERATE_WITH_python_-c_import_secrets_print_secrets.token_urlsafe_48
ADMIN_API_KEY=CHANGE_ME_ADMIN_TOKEN_FOR_DEMO
CAMERA_STREAM_TOKEN=CHANGE_ME_CAMERA_STREAM_TOKEN

# AI/ML Settings
INSIGHTFACE_MODEL=buffalo_l
FACE_RECOGNITION_THRESHOLD=0.4
INSIGHTFACE_DET_THRESH=0.5

# Attendance Settings
WORK_START_TIME=08:00
WORK_END_TIME=17:00
LATE_THRESHOLD_MINUTES=15
CHECKIN_COOLDOWN_MINUTES=5
TIMEZONE=Asia/Ho_Chi_Minh

# CORS (danh sách origins được phép, JSON array)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ========================
# Frontend
# ========================
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/api/recognition/stream

# ========================
# Redis (tuỳ chọn)
# ========================
# REDIS_URL=redis://redis:6379/0
